# F1 Race Prediction System – Environment Variables
# Copy this file to .env and fill in real values

# ── MLflow ──────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=f1_race_prediction
MLFLOW_MODEL_NAME=f1_race_predictor

# ── API ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# ── Data Sources ─────────────────────────────────────
# TODO: Replace with your Jolpica / Ergast API key if required
JOLPICA_API_KEY=
# TODO: FastF1 caching directory (absolute path inside container)
FASTF1_CACHE_DIR=data/raw/fastf1_cache

# ── Agent / LLM ──────────────────────────────────────
# TODO: Add your OpenAI API key to enable LLM-powered agent responses
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Monitoring ───────────────────────────────────────
EVIDENTLY_REPORT_DIR=reports/evidently

# ── Prefect ──────────────────────────────────────────
PREFECT_API_URL=
